{
  "version": 1,
  "ecosystems": [
    {
      "name": "cargo",
      "manifest_globs": [
        "Cargo.toml",
        "apps/*/Cargo.toml",
        "crates/*/Cargo.toml"
      ],
      "lockfile": "Cargo.lock",
      "update": "dependabot:cargo:/",
      "policy": "ADR 0012 and deny.toml"
    },
    {
      "name": "npm-workspace",
      "manifest_globs": [
        "package.json",
        "apps/desktop/package.json",
        "apps/hosted/package.json"
      ],
      "lockfile": "package-lock.json",
      "update": "dependabot:npm:/",
      "policy": "ADR 0012 and ADR 0022 supply-chain review plus exact workspace manifest pins and one root package-lock.json"
    }
  ]
}
