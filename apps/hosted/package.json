{
  "name": "@antennabench/hosted",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run site:build && npm run check && npm run build:foundation && npm run site:check && npm run site:dry-build",
    "build:foundation": "npm run build:development && npm run build:preview && npm run build:production",
    "build:development": "wrangler deploy --dry-run --env= --containers-rollout=none --outdir dist/development",
    "build:preview": "wrangler deploy --dry-run --env preview --containers-rollout=none --outdir dist/preview",
    "build:production": "wrangler deploy --dry-run --env production --containers-rollout=none --outdir dist/production",
    "check": "npm run types:check && npm run site:types:check && tsc --noEmit",
    "deploy:site": "npm run site:build && npm run site:check && wrangler deploy --config wrangler.site.jsonc",
    "site:build": "npm run site:sample:check && npm run site:social:check && node ../../scripts/run-hosted-astro.mjs build",
    "site:check": "node ../../scripts/validate-hosted-site.mjs",
    "site:dry-build": "wrangler deploy --dry-run --config wrangler.site.jsonc --outdir dist/site-deploy",
    "site:sample": "node ../../scripts/generate-hosted-sample.mjs",
    "site:sample:check": "node ../../scripts/generate-hosted-sample.mjs --check",
    "site:social": "node ../../scripts/generate-hosted-social-card.mjs",
    "site:social:check": "node ../../scripts/generate-hosted-social-card.mjs --check",
    "site:types:check": "tsc --noEmit --project tsconfig.site.json",
    "test": "vitest run --config ../../vitest.config.mjs --project hosted-worker",
    "types": "wrangler types worker-configuration.d.ts",
    "types:check": "wrangler types --check worker-configuration.d.ts"
  },
  "dependencies": {
    "@cloudflare/containers": "0.3.7"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "astro": "7.1.1",
    "sharp": "0.34.5",
    "typescript": "7.0.2",
    "vitest": "4.1.10",
    "wrangler": "4.111.0"
  }
}
