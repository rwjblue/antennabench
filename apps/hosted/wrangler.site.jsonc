{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "antennabench-site",
  "compatibility_date": "2026-07-17",
  "workers_dev": false,
  "preview_urls": false,
  "assets": {
    "directory": "./dist/site",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "404-page"
  }
}
