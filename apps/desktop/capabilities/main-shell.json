{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-shell",
  "description": "Main shell capability limited to setup, operator-triggered local control, the manual conductor, opening sessions, lossless export, and active reports.",
  "windows": ["main"],
  "permissions": [
    "allow-review-session-setup",
    "allow-request-station-location",
    "allow-load-station-preferences",
    "allow-create-session-from-review",
    "allow-open-session-bundle",
    "allow-export-active-session",
    "allow-export-active-session-report",
    "allow-active-session-report",
    "allow-refresh-active-session-report",
    "allow-active-session-conductor",
    "allow-mutate-active-session-conductor",
    "allow-active-session-wsjtx-status",
    "allow-start-active-session-wsjtx",
    "allow-stop-active-session-wsjtx",
    "allow-advance-active-session-wspr-live",
    "allow-import-active-session-wspr-live",
    "allow-import-active-session-rbn",
    "allow-antenna-controller-profiles",
    "allow-save-antenna-controller-profile",
    "allow-active-session-antenna-controller",
    "allow-attach-active-session-antenna-controller",
    "allow-run-active-session-antenna-controller"
  ]
}
