#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; -*-
#MISE description="Verify and extract one non-secret native artifact for protected signing"
#USAGE arg "<input>" help="Downloaded #35 target artifact directory"
#USAGE arg "<output>" help="Clean output directory for AntennaBench.app"
#USAGE arg "<target>" help="Native Rust target" {
#USAGE   choices "aarch64-apple-darwin" "x86_64-apple-darwin"
#USAGE }
#USAGE arg "<tag>" help="Exact vMAJOR.MINOR.PATCH release tag"
#USAGE arg "<commit>" help="Expected full source commit"

set -euo pipefail

node scripts/desktop-publication.mjs prepare \
  --input "$usage_input" \
  --output "$usage_output" \
  --target "$usage_target" \
  --tag "$usage_tag" \
  --expected-commit "$usage_commit"
