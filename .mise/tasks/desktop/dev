#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; -*-
#MISE description="Launch the desktop shell in development mode"
#MISE raw=true

set -euo pipefail

cd apps/desktop
tauri_cli="$(command -v cargo-tauri)"
case "$(uname -s)" in
  MINGW* | MSYS* | CYGWIN*)
    export ANTENNABENCH_CARGO_CLI="$(cygpath -w "$(command -v cargo)")"
    export ANTENNABENCH_TAURI_CLI="$(cygpath -w "$tauri_cli")"
    export ANTENNABENCH_TAURI_DIR="$(cygpath -w "$PWD")"
    export ANTENNABENCH_WINDOWS_PATH="$(cygpath -wp "$PATH")"
    MSYS2_ARG_CONV_EXCL='*' MSYS2_ENV_CONV_EXCL='*' powershell.exe \
      -NoLogo -NoProfile -NonInteractive -Command '
        $ErrorActionPreference = "Stop"
        $cargoDirectory = Split-Path -Parent $env:ANTENNABENCH_CARGO_CLI
        $env:Path = "$cargoDirectory;$env:ANTENNABENCH_WINDOWS_PATH"
        Set-Location -LiteralPath $env:ANTENNABENCH_TAURI_DIR
        $cargo = Get-Command cargo -CommandType Application -ErrorAction Stop
        Write-Host "Using cargo: $($cargo.Source)"
        & $env:ANTENNABENCH_TAURI_CLI dev
        exit $LASTEXITCODE
      '
    ;;
  *)
    exec "$tauri_cli" dev
    ;;
esac
