#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; -*-
#MISE description="Launch the desktop shell in development mode"
#MISE raw=true

set -euo pipefail

cd apps/desktop
tauri_cli="$(command -v cargo-tauri)"
case "$(uname -s)" in
  MINGW* | MSYS* | CYGWIN*)
    # Native Tauri child processes need Windows paths after Git Bash starts the task.
    export PATH="$(cygpath -wp "$PATH")"
    ;;
esac
exec "$tauri_cli" dev
