#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; -*-
#MISE description="Build the desktop shell without packaging"

set -euo pipefail

cd apps/desktop
tauri_cli="$(command -v cargo-tauri)"
case "$(uname -s)" in
  MINGW* | MSYS* | CYGWIN*)
    # Native Tauri child processes need Windows paths after Git Bash starts the task.
    export PATH="$(cygpath -wp "$PATH")"
    export MSYS2_ENV_CONV_EXCL="${MSYS2_ENV_CONV_EXCL:+${MSYS2_ENV_CONV_EXCL};}PATH"
    ;;
esac
"$tauri_cli" build --debug --no-bundle
