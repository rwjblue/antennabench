#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; -*-
#MISE description="Verify standalone and embedded report styles in real browser CSP boundaries"

set -euo pipefail

report_dir="target/desktop-report-browser"
mkdir -p "$report_dir"

cargo run -q -p antennabench-report --example render_canonical_sample -- \
  "$report_dir/full.html"
cargo run -q -p antennabench-report --example render_canonical_sample -- \
  "$report_dir/summary.html" --summary
node scripts/desktop-report-frame-browser.mjs \
  "$report_dir/full.html" "$report_dir/summary.html"
