#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; -*-
#MISE description="Run Rust tests"

set -euo pipefail

if [[ "${OS:-}" == "Windows_NT" ]]; then
  export ANTENNABENCH_WINDOWS_TEST_MANIFEST=1
fi

# Preserve all-target coverage for the portable crates. The desktop binary is
# a two-line Tauri entry point; its Rust behavior and tests live in the library.
cargo test --workspace --exclude antennabench-desktop --all-targets
cargo test --package antennabench-desktop --lib
