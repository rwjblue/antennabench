#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; -*-
#MISE description="Run Rust tests"

set -euo pipefail

if [[ "${OS:-}" == "Windows_NT" ]]; then
  export ANTENNABENCH_WINDOWS_TEST_MANIFEST=1
fi

# Exercise every test-bearing target. The desktop binary is a two-line Tauri
# entry point whose generated test harness conflicts with Tauri's app manifest.
cargo test --workspace --lib --tests --benches --examples
