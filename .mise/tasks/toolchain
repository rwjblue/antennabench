#!/usr/bin/env bash
# -*- mode: sh; sh-shell: bash; -*-
#MISE description="Verify the single supported Rust toolchain pin"

set -euo pipefail

workspace_version="$(sed -n 's/^rust-version = "\([^"]*\)"$/\1/p' Cargo.toml)"
toolchain_version="$(sed -n 's/^channel = "\([^"]*\)"$/\1/p' rust-toolchain.toml)"
mise_version="$(sed -n 's/^rust = { version = "\([^"]*\)".*$/\1/p' .mise/config.toml)"
active_version="$(rustc --version | awk '{ print $2 }')"

expected="$toolchain_version"
for declared in \
  "Cargo.toml:$workspace_version" \
  ".mise/config.toml:$mise_version" \
  "active rustc:$active_version"
do
  source="${declared%%:*}"
  version="${declared#*:}"
  if [[ -z "$expected" || "$version" != "$expected" ]]; then
    echo "Rust toolchain mismatch: rust-toolchain.toml=$expected, $source=$version" >&2
    exit 1
  fi
done

while IFS= read -r -d '' manifest; do
  if ! grep -q '^rust-version\.workspace = true$' "$manifest"; then
    echo "Rust toolchain mismatch: $manifest must inherit rust-version.workspace" >&2
    exit 1
  fi
done < <(find apps crates -name Cargo.toml -type f -print0)

echo "Rust toolchain pins agree on $expected"
